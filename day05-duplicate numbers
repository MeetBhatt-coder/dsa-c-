#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cout<<"Enter the size of the array: ";
    cin>>n;
    int arr[n];
    cout<<"Enter the elements of the array: ";
    for(int i=0;i<n;i++)
    {
        cin>>arr[i];
    }

    bool found=false;
    bool visited[n];
    for(int i=0;i<n;i++)
    {
        visited[i]=false;
    }

    cout<<"Duplicate numbers in the array are: ";
    for(int i=0;i<n;i++)
    {
        for(int j=i+1;j<n;j++)
        {
            if(arr[i]==arr[j] && visited[i]==false)
            {
                cout<<arr[i]<<" ";
                visited[i]=true;
                found=true;
                break;
            }
        }
    }

    if(!found)
    {
        cout<<"No duplicate number found in the array."<<endl;
    }
    else
    {
        cout<<endl;
    }

    return 0;
}
