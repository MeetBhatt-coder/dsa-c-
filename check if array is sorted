#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cout<<"Enter the size of array: ";
    cin>>n;
    int arr[n];
    cout<<"Enter the elements of array: ";
    for(int i=0;i<n;i++)
        cin>>arr[i];
    bool sorted = true;
    for(int i=1;i<n;i++)
    {
        if(arr[i]<arr[i-1])
        {
            sorted = false;
            break;
        }
    }
    if(sorted)
        cout<<"The array is sorted."<<endl;
    else
        cout<<"The array is not sorted."<<endl;
    return 0;
}
